# Feature list bhi save karo
with open('feature_cols.pkl', 'wb') as f:
    pickle.dump(feature_cols, f)

print()
print("  [OK] defect_prediction_model.pkl  - main model")
print("  [OK] label_encoders.pkl           - encoders")
print("  [OK] feature_cols.pkl             - feature list")
